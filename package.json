{
  "name": "web-llm-worker",
  "version": "1.0.0",
  "description": "Singleton browser worker backend for Transformers.js WebGPU Bonsai inference.",
  "type": "module",
  "main": "./dist/rewrite-llm.js",
  "module": "./dist/rewrite-llm.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json && node scripts/copy-usage.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "download:model:q2f16": "node scripts/download-bonsai-q2f16.mjs",
    "serve:test": "node scripts/test-server.mjs",
    "verify:model-serving": "node scripts/verify-model-serving.mjs",
    "verify:browser": "node scripts/verify-browser.mjs",
    "verify:real-tool-call": "node scripts/verify-real-tool-call.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "keywords": [
    "transformers.js",
    "webgpu",
    "sharedworker",
    "bonsai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
